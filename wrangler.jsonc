{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sancheck-attendance",
  "compatibility_date": "2026-04-06",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sancheck-production",
      "database_id": "local-db-id"
    }
  ]
}
